// Prisma schema — Próxima Consulta
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth
// ---------------------------------------------------------------------------

model Professional {
  id                String    @id @default(uuid())
  email             String    @unique
  name              String
  passwordHash      String?
  emailVerifiedAt   DateTime?
  emailVerifyToken  String?
  resetPasswordToken String?
  resetPasswordExpiresAt DateTime?
  failedLoginAttempts Int     @default(0)
  lockedUntil       DateTime?
  totpSecret        Bytes?
  totpEnabled       Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  oauthAccounts     OauthAccount[]
  availabilities    Availability[]
  calendarSyncs     CalendarSync[]
  patients          Patient[]
  appointments      Appointment[]
  conversations     Conversation[]
  subscriptions     Subscription[]
  auditLogs         AuditLog[]

  @@map("professional")
}

model OauthAccount {
  id                     String   @id @default(uuid())
  professionalId         String
  provider               String   // "google"
  providerAccountId      String
  encryptedAccessToken   String
  encryptedRefreshToken  String?
  tokenExpiresAt         DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  professional           Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([professionalId, provider])
  @@map("oauth_account")
}

// ---------------------------------------------------------------------------
// Schedule
// ---------------------------------------------------------------------------

model Availability {
  id                    String   @id @default(uuid())
  professionalId        String
  dayOfWeek             Int      // 0=Sun … 6=Sat
  startTime             String   // HH:mm
  endTime               String   // HH:mm
  slotDurationMinutes   Int
  breakDurationMinutes  Int      @default(0)
  isActive              Boolean  @default(true)
  minAdvanceHours       Int      @default(2)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  professional          Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek])
  @@map("availability")
}

model CalendarSync {
  id                       String    @id @default(uuid())
  professionalId           String
  provider                 String    // "google" | "outlook"
  encryptedAccessToken     String
  encryptedRefreshToken    String?
  tokenExpiresAt           DateTime?
  webhookChannelId         String?
  webhookExpiration        DateTime?
  lastSyncedAt             DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  professional             Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, provider])
  @@map("calendar_sync")
}

// ---------------------------------------------------------------------------
// Patient
// ---------------------------------------------------------------------------

model Patient {
  id                  String    @id @default(uuid())
  professionalId      String
  phoneNumber         String
  name                String?
  dateOfBirth         DateTime?
  consentRecordedAt   DateTime?
  anonymizedAt        DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  professional        Professional  @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  appointments        Appointment[]
  waitlistEntries     WaitlistEntry[]
  conversations       Conversation[]
  interactionRecords  InteractionRecord[]

  @@unique([professionalId, phoneNumber])
  @@index([professionalId])
  @@map("patient")
}

// ---------------------------------------------------------------------------
// Booking
// ---------------------------------------------------------------------------

model Appointment {
  id                      String    @id @default(uuid())
  professionalId          String
  patientId               String
  startAt                 DateTime
  endAt                   DateTime
  status                  AppointmentStatus @default(pending)
  serviceType             String
  notes                   String?
  externalCalendarEventId String?
  idempotencyKey          String    @unique
  lastRemindedAt          DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  professional            Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  patient                 Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([professionalId, startAt])
  @@index([professionalId, startAt])
  @@index([patientId])
  @@map("appointment")
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
  completed
  no_show
}

model WaitlistEntry {
  id             String   @id @default(uuid())
  professionalId String
  patientId      String
  requestedDate  DateTime
  notifiedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([professionalId, requestedDate])
  @@map("waitlist_entry")
}

// ---------------------------------------------------------------------------
// Conversation
// ---------------------------------------------------------------------------

model Conversation {
  id             String             @id @default(uuid())
  professionalId String
  patientId      String
  state          ConversationState  @default(IDLE)
  collectedData  Json               @default("{}")
  pendingSlotId  String?
  expiresAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  professional   Professional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  patient        Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@index([professionalId, patientId])
  @@map("conversation")
}

enum ConversationState {
  IDLE
  TRIAGING
  BOOKING_COLLECTING
  BOOKING_CONFIRMING
  CANCELLING
  RESCHEDULING
  RESCHEDULING_CONFIRMING
  FAQ
  ESCALATED
  CONCLUDED
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  direction      MessageDirection
  content        String
  whatsappId     String?
  createdAt      DateTime    @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("message")
}

enum MessageDirection {
  inbound
  outbound
}

model InteractionRecord {
  id             String   @id @default(uuid())
  patientId      String
  professionalId String
  type           String   // "whatsapp_message" | "appointment" | "manual_note"
  content        String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@map("interaction_record")
}

// ---------------------------------------------------------------------------
// Billing
// ---------------------------------------------------------------------------

model Subscription {
  id                   String             @id @default(uuid())
  professionalId       String             @unique
  plan                 SubscriptionPlan
  status               SubscriptionStatus @default(trial)
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  asaasSubscriptionId  String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  professional         Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  payments             Payment[]

  @@map("subscription")
}

enum SubscriptionPlan {
  monthly
  semiannual
  annual
}

enum SubscriptionStatus {
  trial
  active
  overdue
  cancelled
  suspended
}

model Payment {
  id               String        @id @default(uuid())
  subscriptionId   String
  asaasPaymentId   String        @unique
  amount           Decimal       @db.Decimal(10, 2)
  method           PaymentMethod
  status           PaymentStatus
  paidAt           DateTime?
  createdAt        DateTime      @default(now())

  subscription     Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("payment")
}

enum PaymentMethod {
  credit_card
  pix
  boleto
}

enum PaymentStatus {
  pending
  confirmed
  overdue
  refunded
  cancelled
}

// ---------------------------------------------------------------------------
// Audit (append-only — no updatedAt by design)
// ---------------------------------------------------------------------------

model AuditLog {
  id             String   @id @default(uuid())
  actorId        String
  actorType      String   // "professional" | "system"
  resourceType   String
  resourceId     String
  action         String
  oldValue       Json?
  newValue       Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  professional   Professional @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
  @@index([resourceType, resourceId])
  @@map("audit_log")
}
